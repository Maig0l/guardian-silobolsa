# Alert Thresholds
CO2_THRESHOLD=2000
TEMPERATURE_THRESHOLD=30
HUMIDITY_THRESHOLD=70

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
