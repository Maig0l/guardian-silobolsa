# ════════════════════════════════════════════════════════════
#  Guardián Silobolsa — Variables de entorno
#  Copiá este archivo a .env y completá los valores reales
#  NUNCA commites el archivo .env al repositorio
# ════════════════════════════════════════════════════════════

# ── Servidor backend ──────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Base de datos (MariaDB) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=guardian
DB_PASSWORD=guardian_pass
DB_NAME=guardian_silobolsa
DB_ROOT_PASSWORD=root_secret

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d

# ── API Key para sensores (HMAC-SHA256) ───────────────────────
API_KEY_SECRET=cambia_esto_por_otro_secreto_seguro

# ── MQTT (Mosquitto) ──────────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost
MQTT_PORT=1883
MQTT_USERNAME=guardian_backend
MQTT_PASSWORD=mqtt_pass
MQTT_TOPIC_PREFIX=guardian/readings

# ── Email (SMTP / Nodemailer) ─────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM="Guardián Silobolsa <tu_email@gmail.com>"

# ── WhatsApp (Twilio) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Umbrales de alerta ────────────────────────────────────────
ALERT_TEMP_MAX=35
ALERT_HUM_MAX=14
ALERT_CO2_MAX=5000

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api
VITE_WS_URL=ws://localhost:3000
