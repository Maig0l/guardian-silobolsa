# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=guardian_user
DB_PASSWORD=secure_password
DB_NAME=guardian_silobolsa

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=guardian_backend
