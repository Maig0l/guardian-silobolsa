{
  "name": "@guardian-silobolsa/backend",
  "version": "1.0.0",
  "description": "Backend para el sistema de monitoreo Guardián Silobolsa",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "migration:create": "mikro-orm migration:create",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:down",
    "migration:fresh": "mikro-orm migration:fresh --seed",
    "schema:create": "tsc --noEmit false && mikro-orm schema:create --run",
    "schema:update": "tsc --noEmit false && mikro-orm schema:update --run"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.3.0",
    "@mikro-orm/mariadb": "^6.3.0",
    "@mikro-orm/migrations": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.7.0",
    "nodemailer": "^6.9.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^6.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  },
  "mikro-orm": {
    "useTsNode": false,
    "configPaths": [
      "./dist/mikro-orm.config.js"
    ]
  }
}