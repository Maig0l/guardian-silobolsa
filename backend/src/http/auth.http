@base = http://localhost:3000/api
@contentType = Content-Type: application/json

### ── Registrar usuario ──────────────────────────────────────────────────────
POST {{base}}/auth/register
{{contentType}}

{
  "nombre": "Alejandro",
  "apellido": "García",
  "email": "ale@guardian.com",
  "password": "Segura123!",
  "telefono": "+5493412345678"
}

### ── Login ───────────────────────────────────────────────────────────────────
# @name login
POST {{base}}/auth/login
{{contentType}}

{
  "email": "ale@guardian.com",
  "password": "Segura123!"
}

### ── Perfil del usuario autenticado ─────────────────────────────────────────
# Copiá el token del response anterior en la variable @token
