@base = http://localhost:3000/api
@contentType = Content-Type: application/json
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhbGVAZ3VhcmRpYW4uY29tIiwicm9sZSI6IlVTRVIiLCJpYXQiOjE3NzQxMjY3NTAsImV4cCI6MTc3NDczMTU1MH0.IX8yQde1btfDvADXNQGJ6bf3yMDXkG8BbBPF4AEtbEU
@auth = Authorization: Bearer {{token}}
@fieldId = 2
@silobagId = 2
@sensorId = 5

### ── Listar silobolsas del campo ────────────────────────────────────────────
GET {{base}}/fields/{{fieldId}}/silobolsas
{{auth}}

### ── Ver silobolsa por ID ───────────────────────────────────────────────────
GET {{base}}/fields/{{fieldId}}/silobolsas/{{silobagId}}
{{auth}}

### ── Crear silobolsa ────────────────────────────────────────────────────────
POST {{base}}/fields/{{fieldId}}/silobolsas
{{auth}}
{{contentType}}

{
  "marca": "Richiger",
  "capacidad_max": 180,
  "ubicacion": "Lote sur, cabecera derecha",
  "grano": "GIRASOL",
  "observaciones": "Embolsado en marzo 2024"
}

### ── Actualizar silobolsa ───────────────────────────────────────────────────
PATCH {{base}}/fields/{{fieldId}}/silobolsas/{{silobagId}}
{{auth}}
{{contentType}}

{
  "estado": "LLENO",
  "observaciones": "Control realizado 15/06/2024 sin novedades"
}

### ── Vincular sensor a silobolsa ────────────────────────────────────────────
POST {{base}}/fields/{{fieldId}}/silobolsas/{{silobagId}}/link
{{auth}}
{{contentType}}

{
  "sensor_id": {{sensorId}}
}

### ── Desvincular sensor de silobolsa ────────────────────────────────────────
DELETE {{base}}/fields/{{fieldId}}/silobolsas/{{silobagId}}/link
{{auth}}

### ── Eliminar silobolsa ─────────────────────────────────────────────────────
DELETE {{base}}/fields/{{fieldId}}/silobolsas/{{silobagId}}
{{auth}}
