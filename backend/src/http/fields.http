@base = http://localhost:3000/api
@contentType = Content-Type: application/json
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiZW1haWwiOiJhbGVAZ3VhcmRpYW4uY29tIiwicm9sZSI6IlVTRVIiLCJpYXQiOjE3NzQxMjY3NTAsImV4cCI6MTc3NDczMTU1MH0.IX8yQde1btfDvADXNQGJ6bf3yMDXkG8BbBPF4AEtbEU
@auth = Authorization: Bearer {{token}}

### ── Listar campos del usuario ──────────────────────────────────────────────
GET {{base}}/fields
{{auth}}

### ── Crear campo ─────────────────────────────────────────────────────────────
POST {{base}}/fields
{{auth}}
{{contentType}}

{
  "nombre": "La Esperanza",
  "ubicacion": "Armstrong, Santa Fe"
}

### ── Ver campo por ID ────────────────────────────────────────────────────────
@fieldId = 1
GET {{base}}/fields/{{fieldId}}
{{auth}}

### ── Actualizar campo ────────────────────────────────────────────────────────
PATCH {{base}}/fields/{{fieldId}}
{{auth}}
{{contentType}}

{
  "nombre": "Campo La Esperanza (actualizado)",
  "ubicacion": "Ruta 33 km 145, Venado Tuerto, Santa Fe",
  "estado": "ACTIVO"
}

### ── Eliminar campo ──────────────────────────────────────────────────────────
DELETE {{base}}/fields/{{fieldId}}
{{auth}}
